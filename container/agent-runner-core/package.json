    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cron-parser": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
