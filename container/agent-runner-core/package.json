{
  "name": "happyclaw-agent-runner-core",
  "version": "1.0.0",
  "type": "module",
  "description": "Shared core for HappyClaw agent runners — types, IPC, plugins, context manager",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
